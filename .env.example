# Mad Krapow — Monorepo Environment Variables
# Copy to .env.local (web) or use as reference for mobile dart-define args.
# See apps/web/.env.local.example and apps/web/.env.test.example for more detail.

# ── Shared (both web & mobile) ──────────────────────────────────
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=sb_secret_xxx

# ── Web (apps/web/.env.local) ───────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_xxx
NEXT_PUBLIC_URL=http://localhost:3000

# Stripe
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
STRIPE_WEBHOOK_SECRET=whsec_xxx

# Lalamove
LALAMOVE_API_KEY=pk_test_xxx
LALAMOVE_API_SECRET=sk_test_xxx
LALAMOVE_ENV=sandbox
LALAMOVE_MARKET=MY
LALAMOVE_CITY_NAME=Shah Alam
LALAMOVE_WEBHOOK_URL=https://yourdomain.com/api/webhooks/lalamove
LALAMOVE_ENABLED=true
LALAMOVE_DEFAULT_STANDARD_SERVICE_TYPE=MOTORCYCLE
LALAMOVE_DEFAULT_BULK_SERVICE_TYPE=CAR
LALAMOVE_POLLING_INTERVAL_MS=30000

# Google Maps
NEXT_PUBLIC_GOOGLE_MAPS_KEY=AIzaSyxxx

# Resend
RESEND_API_KEY=re_xxx

# Store Location
STORE_LATITUDE=3.1390
STORE_LONGITUDE=101.6869
STORE_ADDRESS=123 Thai Food Street, Shah Alam, Malaysia
STORE_CITY=Shah Alam
STORE_PHONE=+60123456789

# ── Mobile (apps/mobile/) ───────────────────────────────────────
# Pass via --dart-define when running:
#   flutter run --dart-define=SUPABASE_URL=... --dart-define=SUPABASE_ANON_KEY=...
# (Uses same Supabase keys as web above)

# ── Optional ────────────────────────────────────────────────────
# SENTRY_DSN=https://xxx@sentry.io/xxx
