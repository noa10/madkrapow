# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here

# Web API (production URL works for all devices including emulator)
# For local dev: use your machine's LAN IP for physical devices, e.g. http://192.168.1.x:3000
# iOS Simulator: http://localhost:3000
# Android Emulator: http://10.0.2.2:3000
# Physical Device: http://<YOUR_LAN_IP>:3000
WEB_API_URL=https://www.madkrapow.com

# Store location (for delivery quoting)
STORE_LATITUDE=3.1390
STORE_LONGITUDE=101.6869
STORE_ADDRESS=123 Thai Food Street, Kuala Lumpur, Malaysia

# Google Sign-In
GOOGLE_WEB_CLIENT_ID=your-google-web-client-id-here
GOOGLE_ANDROID_CLIENT_ID=your-google-android-client-id-here
