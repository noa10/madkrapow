# Public GrabFood store URL used by the homepage "Order on GrabFood" CTA.
# Set this in your deployment environment (Vercel/etc.). Falls back to "#" if unset.
NEXT_PUBLIC_GRABFOOD_URL=

# Rich /menu catalog (signature hero + rich card grid). Set to "0" to fall back to the simple row list.
NEXT_PUBLIC_RICH_MENU_V2=

# WhatsApp Cloud API (Meta) — bot ordering via WhatsApp
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=

# Telegram Bot API token (from @BotFather). Format: bot<token>
TELEGRAM_BOT_TOKEN=

# Optional secret token for webhook verification (set in Telegram webhook config)
TELEGRAM_WEBHOOK_SECRET=

# Optional: Kitchen Telegram group chat ID for order notifications
TELEGRAM_KITCHEN_GROUP_CHAT_ID=
