# Public GrabFood store URL used by the homepage "Order on GrabFood" CTA.
# Set this in your deployment environment (Vercel/etc.). Falls back to "#" if unset.
NEXT_PUBLIC_GRABFOOD_URL=

# Rich /menu catalog (signature hero + rich card grid). Set to "0" to fall back to the simple row list.
NEXT_PUBLIC_RICH_MENU_V2=
