{
  "name": "madkrapow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @madkrapow/web",
    "build": "npm run build --workspace @madkrapow/web",
    "start": "npm run start --workspace @madkrapow/web",
    "lint": "eslint apps/web/src apps/web/middleware.ts e2e playwright.config.ts vitest.config.ts",
    "lint:parity": "node scripts/check-order-status-parity.mjs",
    "typecheck": "tsc --project apps/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate-types": "bash tooling/generate-types.sh",
    "prepare": "[ -z \"$CI\" ] && husky || true"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.8.0",
    "@vitest/coverage-v8": "^4.1.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "playwright": "^1.58.2",
    "supabase": "^2.98.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.4"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --project apps/web/tsconfig.json --noEmit'"
    ]
  },
  "overrides": {
    "postcss": "^8.5.10",
    "next": {
      "postcss": "^8.5.10"
    }
  }
}
