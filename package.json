{
  "name": "madkrapow",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev --workspace @madkrapow/web",
    "build": "npm run build --workspace @madkrapow/web",
    "start": "npm run start --workspace @madkrapow/web",
    "lint": "eslint apps/web/src apps/web/middleware.ts e2e playwright.config.ts vitest.config.ts",
    "typecheck": "tsc --project apps/web/tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "generate-types": "npx supabase gen types typescript --local > packages/shared-types/typescript/db.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.5",
    "@playwright/test": "^1.59.1",
    "@types/node": "^25.5.2",
    "@vitest/coverage-v8": "^4.1.2",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.1.7",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "playwright": "^1.58.2",
    "supabase": "^2.84.8",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --project apps/web/tsconfig.json --noEmit'"
    ]
  }
}
